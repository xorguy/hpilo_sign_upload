# HP iLO 4 certificate upload — runtime configuration
# Copy this file to .env, fill in the values, and run: chmod 600 .env
# NEVER commit .env to version control.

# iLO management interface IP or hostname
ILO_HOST=192.168.x.x

# iLO username (must have config_ilo_priv)
ILO_USER=Administrator

# iLO password
ILO_PASS=your_ilo_password

# Absolute path to the CSR file exported from iLO on the HOST
CSR_PATH=/path/to/ilo_generated.csr
