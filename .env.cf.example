# Cloudflare DNS credentials for acme.sh
# Copy this file to .env.cf, fill in the values, and run: chmod 600 .env.cf
# NEVER commit .env.cf to version control.

# Cloudflare Account ID (found in the Cloudflare dashboard → right sidebar)
CF_Account_ID=your_cloudflare_account_id

# Cloudflare API Token (needs Zone:DNS:Edit permission for the target zone)
CF_Token=your_cloudflare_api_token

# Cloudflare Zone ID (found in the Cloudflare dashboard → right sidebar)
CF_Zone_ID=your_cloudflare_zone_id

# Domain that acme.sh will use to sign the CSR
# Must match the CN / SAN present in the CSR
DOMAIN=ilo.example.com

# Email address for ACME account registration
# Required by ZeroSSL (acme.sh default CA); optional for Let's Encrypt
ACME_EMAIL=admin@example.com
